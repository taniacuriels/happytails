    "@happytails/notifications": "file:../../packages/notifications",
    "@happytails/auth": "file:../../packages/auth",
    "@happytails/design-tokens": "file:../../packages/design-tokens",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "expo": "~51.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0"
  }
